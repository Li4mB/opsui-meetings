{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OpsUI Meetings Dashboard",
  "version": "0.1.2",
  "identifier": "com.opsui.meetings",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run prepare:icons && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpsUI Meetings Dashboard",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "OpsUI",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:opsui-meetings-cache.db"
      ]
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/opsui/opsui-meetings/releases/latest/download/{{target}}-{{arch}}.json",
        "https://github.com/opsui/opsui-meetings/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwM0IzQjQ0NjcxNENDREQKUldUZHpCUm5SRHM3ME9zYzJLV3NwTEZyenlYZjVKTkdMTk5jTklGcHFPRDBKSGNGZTc5aXFvQkQK"
    }
  }
}
